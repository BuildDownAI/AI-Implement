{
  "name": "ai-implement",
  "version": "0.1.0",
  "description": "Polls Linear for issues labeled AI-Implement and runs Claude Code against them via GitHub Actions or Fly Machines.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/BuildDownAI/AI-Implement.git"
  },
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "build:runner:local": "docker build -f Dockerfile.session -t ai-implement-runner:local .",
    "dev:local": "npm run build:runner:local && RUNNER_MODE=local LOCAL_RUNNER_IMAGE=ai-implement-runner:local tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^22.0.0",
    "jsdom": "^29.1.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  }
}
